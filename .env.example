# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/skin_disease_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=skin_disease_db

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=false

# Model Configuration
MODEL_PATH=ml/model_weights/efficientnet_skin_disease.keras
CONFIDENCE_THRESHOLD=0.5

# LLM Configuration
# Available providers: gemini (recommended), openai

# Option 1: Google Gemini API (RECOMMENDED - fast, free tier available)
# Get your API key at: https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GOOGLE_API_KEY=your-gemini-api-key-here

# Option 2: OpenAI API (fast, pay-as-you-go)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here

# Frontend Configuration
FRONTEND_PORT=8501
API_URL=http://backend:8000

# Kaggle (for dataset download)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key
